datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Employee {
  id         Int             @id @default(autoincrement())
  name       String
  department String
  baseSalary Int
  bonus      Int
  deduction  Int
  createdAt  DateTime        @default(now())

  records    PayrollRecord[]
}

model PayrollRecord {
  id          Int       @id @default(autoincrement())
  month       String
  shouldPay   Int
  realPay     Int
  note        String?
  createdAt   DateTime  @default(now())

  employee    Employee  @relation(fields: [employeeId], references: [id])
  employeeId  Int
}

